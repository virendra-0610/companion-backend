# Copy this file to .env.local only for local testing.
# DO NOT commit .env.local to GitHub.

# Firebase service account JSON from:
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"companion-54a37","private_key_id":"REPLACE_ME","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@companion-54a37.iam.gserviceaccount.com","client_id":"REPLACE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"REPLACE_ME","universe_domain":"googleapis.com"}

# Long random password used to protect cron endpoints.
CRON_SECRET=replace_with_long_random_secret

# Default city/location used by backend when no lat/lon is passed in URL.
DEFAULT_LAT=56.9496
DEFAULT_LON=24.1052
DEFAULT_CITY=Riga
